{
  "expo": {
    "name": "Ahmed",
    "slug": "ahmed",
    "version": "1.0.14",
    "orientation": "portrait",
    "scheme": "ahmed",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e104e"
    },
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "bundleIdentifier": "sa.pm.ahmed",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "sa.pm.ahmed",
      "versionCode": 15,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e104e"
      }
    },
    "extra": {
      "apiUrl": "https://ahmed.pm.sa/api",
      "eas": {
        "projectId": "85d588cc-f97a-4907-a248-0e778d83d674"
      }
    }
  }
}
